# Child repo working copies — they have their own remotes and live as siblings, not subdirectories.
# When you `git clone` a child repo into this metarepo's parent directory, add it here.
# Example:
# my-service-a/
# my-service-b/

# Machine-local config — deploy targets, SSH hosts, identities that vary per workstation
*.local.json
.*-local.json

# Git worktrees + scratch
.worktrees/
worktree-*/
scratch/
tmp/

# OS junk
.DS_Store
Thumbs.db

# Editor
.vscode/settings.json
.idea/

# Session-manifest sandbox (real session manifests live under planning/<domain>/sessions/ and ARE checked in)
*.scratch.jsonl
